# EduFinance local configuration example.
# Copy this file to .env before local launch:
#   cp .env.example .env
# Then change values in .env if needed.

# Flask secret key for sessions and CSRF protection.
# For real deployment, replace this with a long random value and do not commit .env.
SECRET_KEY=change-me-to-a-random-secret-key

# Database connection string.
# Default local SQLite database will be created inside Flask instance folder.
DATABASE_URL=sqlite:///edufinance.db

# Demo accounts created by: flask --app run.py init-db
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=Admin12345!
DEMO_USER_EMAIL=user@example.com
DEMO_USER_PASSWORD=User12345!
